          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titlePart": {
                    "type": "string",
                    "example": "titlepart",
                    "description": "The titlePart is desired to be included in the Original Title of the results."
