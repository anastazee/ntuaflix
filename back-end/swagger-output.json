              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/titleObject"
                  }
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "csv"
                }
              }
            }
          },
          "204": {
            "description": "No title matches the titlePart parameter. No data is returned."
          },
          "400": {
            "description": "Bad Request. Either titlePart is missing from the request body, titlePart is empty or format has a wrong type (different from csv/json). \n   See message for more information.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
